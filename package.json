{
  "name": "spot",
  "version": "2.8.4",
  "private": true,
  "description": "Spot — music downloader",
  "author": "Lerch4ik",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n next,electron -c blue,green \"npm run dev:next\" \"npm run dev:electron\"",
    "dev:next": "next dev",
    "dev:electron": "wait-on http://127.0.0.1:3000 && electron .",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "dist": "next build && electron-builder --win --x64"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-toast": "^1.2.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "electron-store": "^8.2.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.2",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.3.1",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^10.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5",
    "tailwindcss": "^4.3.3",
    "typescript": "5.7.3",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "hono": "4.12.25"
  },
  "build": {
    "appId": "com.lerch4ik.spot",
    "productName": "Spot",
    "afterPack": "electron/after-pack.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*",
          "!node_modules/**/*"
        ]
      },
      {
        "from": ".next/static",
        "to": "standalone/.next/static",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public",
        "to": "standalone/public",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/icon.ico",
      "artifactName": "Spot-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "include": "electron/installer.nsh",
      "shortcutName": "Spot",
      "uninstallDisplayName": "Spot"
    }
  }
}
